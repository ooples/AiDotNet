<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-level NuGet sources are intentionally portable: only nuget.org
    ships in source control. Local-feed entries (development feeds,
    private CI artefact mirrors, etc.) belong in a per-developer
    %appdata%/NuGet/NuGet.Config or a CI-side config so they don't
    break restore on machines that don't have the same paths — the
    earlier hardcoded "C:\Users\cheat\local-nupkg" sources broke CI
    restore (NU1301) on every non-Windows runner and on every dev
    box other than the original author's.
  -->
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
