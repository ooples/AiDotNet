<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
	  <TargetFrameworks>net10.0;net471</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	  <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
	  <LangVersion>latest</LangVersion>
	  <!-- Suppress AIDN001 (missing model metadata) for test mock classes.
	       Mock/fake IFullModel implementations in tests don't need real metadata. -->
	  <NoWarn>$(NoWarn);AIDN001</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <DotNetCliToolReference Include="JetBrains.dotCover.CommandLineTools" Version="2023.2.2" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="System.Net.Http" />
    <PackageReference Include="System.Text.RegularExpressions" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="BenchmarkDotNet" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <PackageReference Include="Moq" />
    <PackageReference Include="Xunit.SkippableFact" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\AiDotNet.csproj" />
    <!-- Opt-in metapackages extracted in audit-2026-05 phase 2c (#14). The test
         project references them so the tests for their types compile after the
         types moved out of the core package:
           - Privacy.HE     → FederatedLearning/SealHomomorphicEncryptionProviderTests.cs
           - Storage.Sqlite → Storage/SqliteSqlSyntaxValidatorTests.cs -->
    <ProjectReference Include="..\..\src\AiDotNet.Privacy.HE\AiDotNet.Privacy.HE.csproj" />
    <ProjectReference Include="..\..\src\AiDotNet.Storage.Sqlite\AiDotNet.Storage.Sqlite.csproj" />
  </ItemGroup>

  <!-- Source generator for auto-generating test scaffolds for untested models -->
  <ItemGroup>
    <ProjectReference Include="..\..\src\AiDotNet.Generators\AiDotNet.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- ModelPerfProbe baseline manifest. The TestScaffoldGenerator reads this AdditionalFile to
       emit [Trait("Speed", "Slow")] on auto-generated scaffolds for models whose probe-measured
       train-step latency or alloc per step exceed the slow thresholds, so the test runner can
       filter slow models out of fast CI lanes via a Speed!=Slow trait filter. The nightly
       perf-probe workflow refreshes this manifest. -->
  <ItemGroup>
    <AdditionalFiles Include="..\..\artifacts\perf-baseline.json" Condition="Exists('..\..\artifacts\perf-baseline.json')" Visible="false" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <ProjectReference Include="..\..\tools\AiDotNet.ProgramSynthesis.Tooling\AiDotNet.ProgramSynthesis.Tooling.csproj" />
    <ProjectReference Include="..\..\src\AiDotNet.Serving\AiDotNet.Serving.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="xunit.runner.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="IntegrationTests\Clustering\ReferenceData\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
