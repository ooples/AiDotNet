<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AiDotNet.Tools.WikiGenerator</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Pulls AiDotNet + deps into output so generated examples can be compile-checked
         in-process (only compiling examples are emitted), and so types resolve. -->
    <ProjectReference Include="..\..\src\AiDotNet.csproj" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
  </ItemGroup>

</Project>
