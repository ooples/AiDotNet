<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AiDotNet.Tools.DocSnippetVerify</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- ProjectReference pulls AiDotNet + all its transitive deps into this tool's
         output, so snippets can be compiled against the real assemblies. -->
    <ProjectReference Include="..\..\src\AiDotNet.csproj" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
  </ItemGroup>

</Project>
