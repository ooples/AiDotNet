<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AiDotNet.Tools.ExampleFixer</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Pulls AiDotNet + deps into output so examples compile against the real assembly,
         and lets us reflect over it to map type names to namespaces. -->
    <ProjectReference Include="..\..\src\AiDotNet.csproj" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
  </ItemGroup>

</Project>
