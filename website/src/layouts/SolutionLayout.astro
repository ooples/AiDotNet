---
import BaseLayout from './BaseLayout.astro';

interface Capability {
  title: string;
  description: string;
  models: string[];
  icon: string;
}

interface Props {
  title: string;
  seoTitle: string;
  seoDescription: string;
  headline: string;
  subheadline: string;
  icon: string;
  painPoints: { problem: string; solution: string }[];
  capabilities: Capability[];
  workflow: { step: string; detail: string }[];
  codeExample: string;
  codeTitle: string;
}

const base = import.meta.env.BASE_URL;
const {
  title, seoTitle, seoDescription, headline, subheadline, icon,
  painPoints, capabilities, workflow, codeExample, codeTitle
} = Astro.props;
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <!-- Hero -->
  <section class="pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-white dark:bg-surface-dark"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-blue/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-purple/10 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="gsap-fade-up text-sm mb-8">
        <ol class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
          <li><a href={base} class="hover:text-slate-900 dark:hover:text-white transition-colors">Home</a></li>
          <li><span class="text-slate-300 dark:text-slate-600">/</span></li>
          <li><a href={`${base}solutions/`} class="hover:text-slate-900 dark:hover:text-white transition-colors">Solutions</a></li>
          <li><span class="text-slate-300 dark:text-slate-600">/</span></li>
          <li class="text-slate-900 dark:text-white font-medium">{title}</li>
        </ol>
      </nav>

      <div class="max-w-4xl">
        <div class="gsap-fade-up flex items-center gap-4 mb-6">
          <div class="w-14 h-14 flex items-center justify-center rounded-2xl bg-gradient-brand text-white">
            <Fragment set:html={icon} />
          </div>
          <span class="px-3 py-1 text-xs font-semibold tracking-wide uppercase rounded-full bg-brand-blue/10 dark:bg-brand-purple/10 text-brand-blue dark:text-brand-purple">
            Industry Solution
          </span>
        </div>
        <h1 class="gsap-fade-up text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-6">{headline}</h1>
        <p class="gsap-fade-up text-lg text-slate-500 dark:text-slate-400 max-w-3xl">{subheadline}</p>
      </div>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="gsap-fade-up text-2xl font-bold text-slate-900 dark:text-white mb-8">Challenges we solve</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {painPoints.map((point) => (
          <div class="gsap-fade-up p-6 rounded-2xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-lg bg-red-500/10 text-red-500">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-1">{point.problem}</h3>
                <p class="text-sm text-slate-500 dark:text-slate-400">{point.solution}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="gsap-fade-up text-2xl font-bold text-slate-900 dark:text-white mb-8">Key capabilities</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {capabilities.map((cap) => (
          <div class="gsap-fade-up p-6 rounded-2xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50 hover:border-brand-blue/30 dark:hover:border-brand-purple/30 transition-colors">
            <div class="w-10 h-10 mb-4 flex items-center justify-center rounded-lg bg-gradient-brand text-white">
              <Fragment set:html={cap.icon} />
            </div>
            <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-2">{cap.title}</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">{cap.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {cap.models.map((model) => (
                <span class="inline-block px-2 py-0.5 text-xs rounded-md bg-slate-100 dark:bg-slate-900/50 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700">
                  {model}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Workflow -->
  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="gsap-fade-up text-2xl font-bold text-slate-900 dark:text-white mb-8">Typical workflow</h2>
      <div class="space-y-4">
        {workflow.map((step, idx) => (
          <div class="gsap-fade-up flex items-start gap-4 p-4 rounded-xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700/30">
            <div class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-gradient-brand text-white text-sm font-bold">
              {idx + 1}
            </div>
            <div>
              <h3 class="text-sm font-semibold text-slate-900 dark:text-white">{step.step}</h3>
              <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">{step.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Code Example -->
  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="gsap-fade-up text-xl font-bold text-slate-900 dark:text-white mb-4">{codeTitle}</h2>
      <div class="gsap-fade-up rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700/50">
        <div class="bg-slate-900 dark:bg-slate-800 px-4 py-2 flex items-center justify-between border-b border-slate-700">
          <span class="text-xs text-slate-400 font-mono">C#</span>
        </div>
        <pre class="p-4 bg-slate-900 dark:bg-slate-800 overflow-x-auto"><code class="text-sm text-slate-300 font-mono whitespace-pre">{codeExample}</code></pre>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-blue/5 to-brand-purple/5"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">
      <h2 class="gsap-fade-up text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-4">
        Build your {title.toLowerCase()} solution today
      </h2>
      <div class="gsap-fade-up flex flex-col sm:flex-row items-center justify-center gap-4 mt-6">
        <a href={`${base}docs/getting-started/installation/`} class="px-8 py-3 text-base font-semibold text-white rounded-xl bg-gradient-brand hover:opacity-90 transition-opacity shadow-lg shadow-brand-blue/25">
          Get Started Free
        </a>
        <a href={`${base}features/`} class="px-8 py-3 text-base font-semibold text-slate-700 dark:text-slate-200 rounded-xl border border-slate-300 dark:border-slate-600 hover:border-brand-blue/50 dark:hover:border-brand-purple/50 transition-colors">
          Browse All Features
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
