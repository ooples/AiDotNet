---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Navbar from '../components/Navbar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Footer from '../components/Footer.astro';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import '@fontsource/jetbrains-mono/400.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description: string;
  activeTab?: string;
}

const { title, description, activeTab } = Astro.props;
const base = import.meta.env.BASE_URL;

const iconPaths: Record<string, string[]> = {
  home: ['m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25'],
  key: ['M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z'],
  chart: ['M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z'],
  card: ['M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z'],
  gear: ['M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z', 'M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z'],
};

const sidebarLinks = [
  { label: 'Dashboard', href: `${base}account/`, icon: 'home', id: 'dashboard' },
  { label: 'API Keys', href: `${base}account/api-keys/`, icon: 'key', id: 'api-keys' },
  { label: 'Usage', href: `${base}account/usage/`, icon: 'chart', id: 'usage' },
  { label: 'Billing', href: `${base}account/billing/`, icon: 'card', id: 'billing' },
  { label: 'Settings', href: `${base}account/settings/`, icon: 'gear', id: 'settings' },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <SEO title={title} description={description} />
  </head>
  <body class="min-h-screen bg-white dark:bg-surface-dark text-slate-900 dark:text-slate-100 font-sans antialiased">
    <Navbar>
      <ThemeToggle slot="theme-toggle" />
    </Navbar>

    <div class="pt-20 min-h-screen">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col lg:flex-row gap-8">
          <!-- Sidebar -->
          <aside class="lg:w-64 shrink-0">
            <nav class="space-y-1 lg:sticky lg:top-24">
              {sidebarLinks.map((link) => (
                <a
                  href={link.href}
                  class:list={[
                    'flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all',
                    activeTab === link.id
                      ? 'bg-gradient-to-r from-brand-blue/10 to-brand-purple/10 text-brand-blue dark:text-brand-purple border border-brand-blue/20 dark:border-brand-purple/20'
                      : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-white/5 hover:text-slate-900 dark:hover:text-white',
                  ]}
                >
                  {iconPaths[link.icon] && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      {iconPaths[link.icon].map((d) => (
                        <path stroke-linecap="round" stroke-linejoin="round" d={d} />
                      ))}
                    </svg>
                  )}
                  {link.label}
                </a>
              ))}

              <div class="pt-4 mt-4 border-t border-slate-200 dark:border-slate-700">
                <button
                  id="sign-out-btn"
                  class="flex items-center gap-3 w-full px-4 py-3 text-sm font-medium text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 rounded-xl transition-all"
                >
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                  </svg>
                  Sign Out
                </button>
              </div>
            </nav>
          </aside>

          <!-- Main content -->
          <div class="flex-1 min-w-0">
            <slot />
          </div>
        </div>
      </div>
    </div>

    <Footer />

    <Analytics />
    <SpeedInsights />

    <script>
      import { supabase } from '../lib/supabase';

      // Auth guard - redirect to login if not authenticated
      async function checkAuth() {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          const base = import.meta.env.BASE_URL || '/';
          const currentPath = window.location.pathname;
          window.location.href = `${base}login/?redirect=${encodeURIComponent(currentPath)}`;
        }
      }

      checkAuth();

      // Sign out handler
      const signOutBtn = document.getElementById('sign-out-btn');
      if (signOutBtn) {
        signOutBtn.addEventListener('click', async () => {
          try {
            const { error } = await supabase.auth.signOut();
            if (error) {
              console.error('Sign out error:', error.message);
            }
          } catch (e) {
            console.error('Sign out failed:', e);
          }
          // Always redirect regardless of sign-out result
          const base = import.meta.env.BASE_URL || '/';
          window.location.href = base;
        });
      }
    </script>

    <!-- GSAP -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      document.addEventListener('DOMContentLoaded', () => {
        const fadeElements = document.querySelectorAll('.gsap-fade-up');
        fadeElements.forEach((el, i) => {
          gsap.fromTo(
            el,
            { opacity: 0, y: 40 },
            {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 85%',
                once: true,
              },
              delay: (i % 3) * 0.1,
            }
          );
        });
      });
    </script>
  </body>
</html>
