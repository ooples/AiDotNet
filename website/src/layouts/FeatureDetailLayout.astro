---
import BaseLayout from './BaseLayout.astro';

interface SubcategoryDetail {
  name: string;
  description: string;
  items: { name: string; detail: string }[];
}

interface Props {
  title: string;
  seoTitle: string;
  seoDescription: string;
  count: string;
  tagline: string;
  description: string;
  icon: string;
  useCases: string[];
  subcategories: SubcategoryDetail[];
  codeExample?: string;
  codeTitle?: string;
}

const base = import.meta.env.BASE_URL;
const {
  title, seoTitle, seoDescription, count, tagline, description, icon,
  useCases, subcategories, codeExample, codeTitle
} = Astro.props;
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <!-- Hero -->
  <section class="pt-32 pb-12 relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-white dark:bg-surface-dark"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-blue/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-purple/10 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="gsap-fade-up text-sm mb-8">
        <ol class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
          <li><a href={base} class="hover:text-slate-900 dark:hover:text-white transition-colors">Home</a></li>
          <li><span class="text-slate-300 dark:text-slate-600">/</span></li>
          <li><a href={`${base}features/`} class="hover:text-slate-900 dark:hover:text-white transition-colors">Features</a></li>
          <li><span class="text-slate-300 dark:text-slate-600">/</span></li>
          <li class="text-slate-900 dark:text-white font-medium">{title}</li>
        </ol>
      </nav>

      <div class="flex items-start gap-6 mb-8">
        <div class="flex-shrink-0 w-16 h-16 flex items-center justify-center rounded-2xl bg-gradient-brand text-white">
          <Fragment set:html={icon} />
        </div>
        <div>
          <div class="flex items-center gap-3 flex-wrap mb-2">
            <h1 class="gsap-fade-up text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 dark:text-white">
              {title}
            </h1>
            <span class="gsap-fade-up inline-block px-3 py-1 text-sm font-bold rounded-full bg-brand-blue/10 dark:bg-brand-purple/10 text-brand-blue dark:text-brand-purple">
              {count}
            </span>
          </div>
          <p class="gsap-fade-up text-lg text-slate-500 dark:text-slate-400 max-w-3xl">{tagline}</p>
        </div>
      </div>

      <p class="gsap-fade-up text-slate-600 dark:text-slate-300 max-w-4xl mb-8 leading-relaxed">{description}</p>

      <!-- Use cases -->
      <div class="gsap-fade-up flex flex-wrap gap-2 mb-8">
        {useCases.map((useCase) => (
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800 text-sm text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
            {useCase}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Detailed subcategories -->
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8">
        {subcategories.map((sub) => (
          <div class="gsap-fade-up">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-2">{sub.name}</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">{sub.description}</p>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {sub.items.map((item) => (
                <div class="p-4 rounded-xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50 hover:border-brand-blue/30 dark:hover:border-brand-purple/30 transition-colors">
                  <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-1">{item.name}</h3>
                  <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">{item.detail}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Code example -->
  {codeExample && (
    <section class="pb-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="gsap-fade-up text-xl font-bold text-slate-900 dark:text-white mb-4">{codeTitle || 'Quick Start Example'}</h2>
        <div class="gsap-fade-up rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700/50">
          <div class="bg-slate-900 dark:bg-slate-800 px-4 py-2 flex items-center justify-between border-b border-slate-700">
            <span class="text-xs text-slate-400 font-mono">C#</span>
            <button
              class="copy-btn p-1 text-slate-400 hover:text-white transition-colors"
              data-copy={codeExample}
              aria-label="Copy code"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </button>
          </div>
          <pre class="p-4 bg-slate-900 dark:bg-slate-800 overflow-x-auto"><code class="text-sm text-slate-300 font-mono whitespace-pre">{codeExample}</code></pre>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-blue/5 to-brand-purple/5"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">
      <h2 class="gsap-fade-up text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-4">
        Start building with {title}
      </h2>
      <p class="gsap-fade-up text-slate-500 dark:text-slate-400 mb-6">
        All {count} implementations are included free under Apache 2.0.
      </p>
      <div class="gsap-fade-up flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${base}docs/getting-started/installation/`}
          class="px-8 py-3 text-base font-semibold text-white rounded-xl bg-gradient-brand hover:opacity-90 transition-opacity shadow-lg shadow-brand-blue/25"
        >
          Install AiDotNet
        </a>
        <a
          href={`${base}features/`}
          class="px-8 py-3 text-base font-semibold text-slate-700 dark:text-slate-200 rounded-xl border border-slate-300 dark:border-slate-600 hover:border-brand-blue/50 dark:hover:border-brand-purple/50 transition-colors"
        >
          Browse All Features
        </a>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.copy-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const text = (btn as HTMLElement).dataset.copy;
          if (text) {
            navigator.clipboard.writeText(text);
            const svg = btn.querySelector('svg');
            if (svg) {
              svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>';
              setTimeout(() => {
                svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
              }, 2000);
            }
          }
        });
      });
    });
  </script>
</BaseLayout>
