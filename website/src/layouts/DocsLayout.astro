---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '' } = Astro.props;
const base = import.meta.env.BASE_URL;

const sidebar = [
  {
    title: 'Getting Started',
    items: [
      { label: 'Installation', href: `${base}docs/getting-started/installation/` },
      { label: 'Quick Start', href: `${base}docs/getting-started/quickstart/` },
    ],
  },
  {
    title: 'Tutorials',
    items: [
      { label: 'Overview', href: `${base}docs/tutorials/` },
      { label: 'Classification', href: `${base}docs/tutorials/classification/` },
      { label: 'Regression', href: `${base}docs/tutorials/regression/` },
      { label: 'Clustering', href: `${base}docs/tutorials/clustering/` },
      { label: 'Computer Vision', href: `${base}docs/tutorials/computer-vision/` },
      { label: 'NLP & RAG', href: `${base}docs/tutorials/nlp/` },
      { label: 'Audio Processing', href: `${base}docs/tutorials/audio/` },
      { label: 'Reinforcement Learning', href: `${base}docs/tutorials/reinforcement-learning/` },
      { label: 'Time Series', href: `${base}docs/tutorials/time-series/` },
      { label: 'LLM Fine-tuning', href: `${base}docs/tutorials/llm-fine-tuning/` },
      { label: 'Distributed Training', href: `${base}docs/tutorials/distributed-training/` },
      { label: 'Deployment', href: `${base}docs/tutorials/deployment/` },
    ],
  },
  {
    title: 'Reference',
    items: [
      { label: 'Neural Networks', href: `${base}docs/reference/neural-networks/` },
      { label: 'Classical ML', href: `${base}docs/reference/classical-ml/` },
      { label: 'Optimizers', href: `${base}docs/reference/optimizers/` },
      { label: 'Loss Functions', href: `${base}docs/reference/loss-functions/` },
      { label: 'LoRA Adapters', href: `${base}docs/reference/lora-adapters/` },
      { label: 'Distributed Strategies', href: `${base}docs/reference/distributed-strategies/` },
      { label: 'YAML Configuration', href: `${base}docs/reference/yaml-configuration/` },
    ],
  },
  {
    title: 'Examples',
    items: [
      { label: 'Tensor Basics', href: `${base}docs/examples/tensor-basics/` },
      { label: 'Neural Network Training', href: `${base}docs/examples/neural-network-training/` },
      { label: 'Clustering', href: `${base}docs/examples/clustering/` },
      { label: 'Transformer', href: `${base}docs/examples/transformer/` },
      { label: 'Mixture of Experts', href: `${base}docs/examples/mixture-of-experts/` },
    ],
  },
  {
    title: 'Community',
    items: [
      { label: 'Contributing', href: `${base}docs/community/contributing/` },
      { label: 'Changelog', href: `${base}docs/community/changelog/` },
      { label: 'Roadmap', href: `${base}docs/community/roadmap/` },
    ],
  },
];

const currentPath = Astro.url.pathname;
const docsSlug = currentPath.replace(/^\/docs\//, '').replace(/\/$/, '');
const editUrl = `https://github.com/ooples/AiDotNet/edit/master/website/src/content/docs/${docsSlug}.md`;
---

<BaseLayout title={`${title} - AiDotNet Docs`} description={description || `${title} documentation for AiDotNet`}>
  <div class="pt-20 min-h-screen">
    <div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Mobile docs nav -->
      <div class="lg:hidden py-4">
        <details class="group border border-slate-200 dark:border-slate-700 rounded-lg">
          <summary class="flex items-center justify-between px-4 py-3 text-sm font-medium text-slate-700 dark:text-slate-300 cursor-pointer">
            Documentation Navigation
            <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>
          <nav class="px-4 pb-4 space-y-4">
            {sidebar.map((section) => (
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">{section.title}</h3>
                <ul class="space-y-1">
                  {section.items.map((item) => {
                    const isActive = currentPath.endsWith(item.href) || currentPath.endsWith(item.href.slice(0, -1));
                    return (
                      <li>
                        <a href={item.href} class:list={['block px-3 py-1.5 text-sm rounded-md transition-colors', isActive ? 'bg-brand-blue/10 text-brand-blue font-medium' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white']}>
                          {item.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))}
          </nav>
        </details>
      </div>

      <div class="flex gap-8">
        <!-- Sidebar -->
        <aside class="hidden lg:block w-64 flex-shrink-0 sticky top-20 h-[calc(100vh-5rem)] overflow-y-auto py-8 pr-4">
          <nav class="space-y-6">
            {sidebar.map((section) => (
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2">
                  {section.title}
                </h3>
                <ul class="space-y-1">
                  {section.items.map((item) => {
                    const isActive = currentPath.endsWith(item.href) || currentPath.endsWith(item.href.slice(0, -1));
                    return (
                      <li>
                        <a
                          href={item.href}
                          class:list={[
                            'block px-3 py-1.5 text-sm rounded-md transition-colors',
                            isActive
                              ? 'bg-brand-blue/10 dark:bg-brand-purple/10 text-brand-blue dark:text-brand-purple font-medium'
                              : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5',
                          ]}
                        >
                          {item.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))}
          </nav>
        </aside>

        <!-- Main content -->
        <div class="flex-1 min-w-0 py-8 lg:py-12">
          <article class="prose prose-slate dark:prose-invert max-w-none prose-headings:font-semibold prose-a:text-brand-blue dark:prose-a:text-brand-purple prose-code:text-brand-blue dark:prose-code:text-brand-purple prose-pre:bg-slate-950 prose-pre:border prose-pre:border-slate-800">
            <h1>{title}</h1>
            <slot />
          </article>

          <!-- Edit on GitHub link -->
          <div class="mt-12 pt-6 border-t border-slate-200 dark:border-slate-800">
            <a
              href={editUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-500 dark:text-slate-400 hover:text-brand-blue dark:hover:text-brand-purple transition-colors"
            >
              Edit this page on GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
