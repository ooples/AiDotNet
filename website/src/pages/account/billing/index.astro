---
import AccountLayout from '../../../layouts/AccountLayout.astro';
const base = import.meta.env.BASE_URL;
---

<AccountLayout title="Billing - AiDotNet" description="Manage your AiDotNet subscription, view invoices, and update payment methods." activeTab="billing">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Billing</h1>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Manage your subscription and payment method</p>
    </div>

    <!-- Current plan -->
    <div class="gsap-fade-up bg-white dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700 p-6">
      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Current Plan</h2>
          <div class="flex items-center gap-3">
            <span id="billing-plan" class="text-2xl font-bold text-slate-900 dark:text-white">Free</span>
            <span id="billing-badge" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400">
              Active
            </span>
          </div>
          <p id="billing-price" class="mt-1 text-sm text-slate-500 dark:text-slate-400">$0/month</p>
        </div>
        <div id="billing-actions">
          <a
            href={`${base}pricing/`}
            class="px-4 py-2 text-sm font-semibold text-white rounded-xl bg-gradient-brand hover:opacity-90 transition-opacity"
            id="billing-upgrade-btn"
          >
            Upgrade to Pro
          </a>
        </div>
      </div>

      <!-- Plan features -->
      <div class="mt-6 pt-6 border-t border-slate-200 dark:border-slate-700">
        <h3 class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-3">Your plan includes:</h3>
        <ul id="plan-features" class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <li class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            8,100+ public classes
          </li>
          <li class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            139 AI/ML modules
          </li>
          <li class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            GPU acceleration (any vendor)
          </li>
          <li class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            Apache 2.0 license
          </li>
        </ul>
      </div>
    </div>

    <!-- Stripe Customer Portal -->
    <div id="portal-section" class="hidden gsap-fade-up bg-white dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700 p-6">
      <h2 class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-4">Payment & Invoices</h2>
      <div class="space-y-4">
        <a
          id="manage-subscription-btn"
          href="#"
          class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-700/50 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
        >
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-slate-900 dark:text-white">Manage Subscription</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">Update payment, switch plans, cancel</p>
            </div>
          </div>
          <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>

        <a
          id="view-invoices-btn"
          href="#"
          class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-700/50 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
        >
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-slate-900 dark:text-white">View Invoices</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">Download past invoices and receipts</p>
            </div>
          </div>
          <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    </div>

    <!-- FAQ -->
    <div class="gsap-fade-up bg-white dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700 p-6">
      <h2 class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-4">Frequently Asked</h2>
      <div class="space-y-4">
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer text-sm font-medium text-slate-700 dark:text-slate-300">
            How do I cancel my subscription?
            <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
            Click "Manage Subscription" above to access the Stripe Customer Portal. From there you can cancel your subscription at any time. Your access will continue until the end of the current billing period.
          </p>
        </details>
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer text-sm font-medium text-slate-700 dark:text-slate-300">
            Can I switch between monthly and yearly?
            <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
            Yes. Use the Stripe Customer Portal to switch between billing periods. Annual plans save you about 17% compared to monthly.
          </p>
        </details>
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer text-sm font-medium text-slate-700 dark:text-slate-300">
            Is the open-source library really free?
            <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
            Yes. AiDotNet is Apache 2.0 licensed. All 8,100+ classes across 139 modules are completely free. Pro and Enterprise tiers add cloud-hosted inference APIs, priority support, and SLA guarantees.
          </p>
        </details>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../../../lib/supabase';

    async function loadBilling() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;

      const { data: profile } = await supabase
        .from('profiles')
        .select('subscription_tier, subscription_status, stripe_customer_id')
        .eq('id', user.id)
        .single();

      if (!profile) return;

      const planEl = document.getElementById('billing-plan');
      const priceEl = document.getElementById('billing-price');
      const badgeEl = document.getElementById('billing-badge');
      const upgradeBtn = document.getElementById('billing-upgrade-btn');
      const portalSection = document.getElementById('portal-section');

      if (profile.subscription_tier === 'pro') {
        if (planEl) planEl.textContent = 'Pro';
        if (priceEl) priceEl.textContent = '$29/month';
        if (upgradeBtn) upgradeBtn.textContent = 'Manage Plan';
        if (portalSection) portalSection.classList.remove('hidden');
      } else if (profile.subscription_tier === 'enterprise') {
        if (planEl) planEl.textContent = 'Enterprise';
        if (priceEl) priceEl.textContent = 'Custom pricing';
        if (upgradeBtn) {
          upgradeBtn.textContent = 'Contact Support';
          upgradeBtn.setAttribute('href', 'mailto:support@aidotnet.dev');
        }
        if (portalSection) portalSection.classList.remove('hidden');
      }

      if (profile.subscription_status !== 'active' && badgeEl) {
        badgeEl.textContent = profile.subscription_status;
        badgeEl.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400';
      }

      // If customer has Stripe ID, link portal buttons
      if (profile.stripe_customer_id) {
        const portalUrl = import.meta.env.PUBLIC_STRIPE_PORTAL_URL || '';
        if (portalUrl) {
          const manageBtn = document.getElementById('manage-subscription-btn');
          const invoicesBtn = document.getElementById('view-invoices-btn');
          if (manageBtn) manageBtn.setAttribute('href', portalUrl);
          if (invoicesBtn) invoicesBtn.setAttribute('href', portalUrl);
        }
      }
    }

    loadBilling();
  </script>
</AccountLayout>
