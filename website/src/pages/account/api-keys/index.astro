---
import AccountLayout from '../../../layouts/AccountLayout.astro';
const base = import.meta.env.BASE_URL;
---

<AccountLayout title="API Keys - AiDotNet" description="Manage your AiDotNet API keys. Create, view, and revoke API keys for inference and model access." activeTab="api-keys">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">API Keys</h1>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Manage your API keys for inference and model access</p>
      </div>
      <button
        id="create-key-btn"
        class="px-4 py-2 text-sm font-semibold text-white rounded-xl bg-gradient-brand hover:opacity-90 transition-opacity flex items-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Create New Key
      </button>
    </div>

    <!-- Create key modal -->
    <div id="create-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm">
      <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-6 w-full max-w-md mx-4 shadow-xl">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Create New API Key</h2>
        <form id="create-key-form" class="space-y-4">
          <div>
            <label for="key-name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              Key Name
            </label>
            <input
              type="text"
              id="key-name"
              required
              class="w-full px-4 py-3 text-sm bg-slate-50 dark:bg-slate-700/50 border border-slate-200 dark:border-slate-600 rounded-xl focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue outline-none transition-all text-slate-900 dark:text-white"
              placeholder="e.g., Production API, Test Key"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Scopes</label>
            <div class="space-y-2">
              <label class="flex items-center gap-2">
                <input type="checkbox" value="inference" checked class="scope-check rounded border-slate-300 text-brand-blue focus:ring-brand-blue" />
                <span class="text-sm text-slate-600 dark:text-slate-300">Inference</span>
              </label>
              <label class="flex items-center gap-2">
                <input type="checkbox" value="embeddings" class="scope-check rounded border-slate-300 text-brand-blue focus:ring-brand-blue" />
                <span class="text-sm text-slate-600 dark:text-slate-300">Embeddings</span>
              </label>
              <label class="flex items-center gap-2">
                <input type="checkbox" value="models" class="scope-check rounded border-slate-300 text-brand-blue focus:ring-brand-blue" />
                <span class="text-sm text-slate-600 dark:text-slate-300">Models</span>
              </label>
            </div>
          </div>
          <div id="create-key-error" class="hidden p-3 text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl"></div>
          <div class="flex gap-3 pt-2">
            <button type="button" id="cancel-create" class="flex-1 px-4 py-2.5 text-sm font-medium text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-slate-700 rounded-xl hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors">
              Cancel
            </button>
            <button type="submit" class="flex-1 px-4 py-2.5 text-sm font-semibold text-white rounded-xl bg-gradient-brand hover:opacity-90 transition-opacity">
              Create Key
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Show new key modal (one-time display) -->
    <div id="new-key-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm">
      <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-6 w-full max-w-lg mx-4 shadow-xl">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">API Key Created</h2>
        </div>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">
          Copy your API key now. You won't be able to see it again.
        </p>
        <div class="flex items-center gap-2 p-3 bg-slate-50 dark:bg-slate-700/50 rounded-xl border border-slate-200 dark:border-slate-600">
          <code id="new-key-value" class="flex-1 text-sm font-mono text-slate-900 dark:text-white break-all"></code>
          <button id="copy-key-btn" class="shrink-0 p-2 text-slate-400 hover:text-brand-blue transition-colors" title="Copy to clipboard">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
            </svg>
          </button>
        </div>
        <button id="close-new-key" class="mt-4 w-full px-4 py-2.5 text-sm font-semibold text-white rounded-xl bg-gradient-brand hover:opacity-90 transition-opacity">
          I've copied my key
        </button>
      </div>
    </div>

    <!-- Keys table -->
    <div class="bg-white dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
      <div id="keys-empty" class="p-12 text-center">
        <svg class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
        </svg>
        <p class="text-sm font-medium text-slate-500 dark:text-slate-400">No API keys yet</p>
        <p class="mt-1 text-xs text-slate-400 dark:text-slate-500">Create your first API key to start making requests.</p>
      </div>
      <table id="keys-table" class="hidden w-full text-sm">
        <thead>
          <tr class="border-b border-slate-200 dark:border-slate-700">
            <th class="text-left py-3 px-4 text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Name</th>
            <th class="text-left py-3 px-4 text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Key</th>
            <th class="text-left py-3 px-4 text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Scopes</th>
            <th class="text-left py-3 px-4 text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Created</th>
            <th class="text-left py-3 px-4 text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Last Used</th>
            <th class="text-right py-3 px-4 text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody id="keys-body" class="divide-y divide-slate-100 dark:divide-slate-800">
        </tbody>
      </table>
    </div>
  </div>

  <script>
    import { supabase } from '../../../lib/supabase';

    let currentUserId: string | null = null;

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    async function loadKeys() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;
      currentUserId = user.id;

      const { data: keys } = await supabase
        .from('user_api_keys')
        .select('*')
        .eq('user_id', user.id)
        .order('created_at', { ascending: false });

      if (keys && keys.length > 0) {
        const emptyEl = document.getElementById('keys-empty');
        const tableEl = document.getElementById('keys-table');
        const tbody = document.getElementById('keys-body');
        if (emptyEl) emptyEl.classList.add('hidden');
        if (tableEl) tableEl.classList.remove('hidden');
        if (tbody) {
          tbody.innerHTML = keys.map(key => {
            const scopes = (key.scopes || []).join(', ');
            const created = new Date(key.created_at).toLocaleDateString();
            const lastUsed = key.last_used_at ? new Date(key.last_used_at).toLocaleDateString() : 'Never';
            const statusClass = key.is_active ? 'text-green-500' : 'text-red-500';
            return `<tr>
              <td class="py-3 px-4 text-slate-700 dark:text-slate-300 font-medium">${escapeHtml(key.key_name)}</td>
              <td class="py-3 px-4 font-mono text-xs text-slate-500 dark:text-slate-400">${escapeHtml(key.key_prefix)}...</td>
              <td class="py-3 px-4 text-slate-500 dark:text-slate-400 text-xs">${escapeHtml(scopes)}</td>
              <td class="py-3 px-4 text-slate-500 dark:text-slate-400">${created}</td>
              <td class="py-3 px-4 text-slate-500 dark:text-slate-400">${lastUsed}</td>
              <td class="py-3 px-4 text-right">
                <button
                  class="revoke-btn text-xs font-medium ${key.is_active ? 'text-red-500 hover:text-red-600' : 'text-slate-400 cursor-not-allowed'}"
                  data-key-id="${key.id}"
                  ${!key.is_active ? 'disabled' : ''}
                >
                  ${key.is_active ? 'Revoke' : 'Revoked'}
                </button>
              </td>
            </tr>`;
          }).join('');

          // Attach revoke handlers
          document.querySelectorAll('.revoke-btn:not([disabled])').forEach(btn => {
            btn.addEventListener('click', async (e) => {
              const keyId = (e.target as HTMLElement).dataset.keyId;
              if (confirm('Are you sure you want to revoke this API key? This cannot be undone.')) {
                await supabase
                  .from('user_api_keys')
                  .update({ is_active: false })
                  .eq('id', keyId);
                loadKeys();
              }
            });
          });
        }
      }
    }

    // Create key modal
    const createBtn = document.getElementById('create-key-btn');
    const createModal = document.getElementById('create-modal');
    const cancelCreate = document.getElementById('cancel-create');

    if (createBtn && createModal) {
      createBtn.addEventListener('click', () => createModal.classList.remove('hidden'));
    }
    if (cancelCreate && createModal) {
      cancelCreate.addEventListener('click', () => createModal.classList.add('hidden'));
    }

    // Create key form
    const createForm = document.getElementById('create-key-form') as HTMLFormElement;
    if (createForm) {
      createForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!currentUserId) return;

        const keyName = (document.getElementById('key-name') as HTMLInputElement).value;
        const scopes = Array.from(document.querySelectorAll('.scope-check:checked'))
          .map(el => (el as HTMLInputElement).value);

        // Generate a random API key
        const array = new Uint8Array(32);
        crypto.getRandomValues(array);
        const fullKey = 'adn_' + Array.from(array, b => b.toString(16).padStart(2, '0')).join('');
        const keyPrefix = fullKey.substring(0, 12);

        // Hash the key for storage using SHA-256 via Web Crypto API
        // Note: For additional security, implement server-side bcrypt hashing via an API endpoint
        const encoder = new TextEncoder();
        const hashBuffer = await crypto.subtle.digest('SHA-256', encoder.encode(fullKey));
        const keyHash = Array.from(new Uint8Array(hashBuffer), b => b.toString(16).padStart(2, '0')).join('');

        const { error } = await supabase
          .from('user_api_keys')
          .insert({
            user_id: currentUserId,
            key_name: keyName,
            key_prefix: keyPrefix,
            key_hash: keyHash,
            scopes: scopes,
          });

        if (error) {
          const errorDiv = document.getElementById('create-key-error');
          if (errorDiv) {
            errorDiv.textContent = 'Failed to create API key. Please try again.';
            errorDiv.classList.remove('hidden');
          }
          return;
        }

        // Hide create modal, show new key modal
        createModal?.classList.add('hidden');
        const newKeyModal = document.getElementById('new-key-modal');
        const newKeyValue = document.getElementById('new-key-value');
        if (newKeyModal) newKeyModal.classList.remove('hidden');
        if (newKeyValue) newKeyValue.textContent = fullKey;

        // Reset form
        createForm.reset();
        loadKeys();
      });
    }

    // Copy key to clipboard
    const copyBtn = document.getElementById('copy-key-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const keyValue = document.getElementById('new-key-value')?.textContent;
        if (keyValue) {
          navigator.clipboard.writeText(keyValue);
          copyBtn.innerHTML = '<svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>';
          setTimeout(() => {
            copyBtn.innerHTML = '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" /></svg>';
          }, 2000);
        }
      });
    }

    // Close new key modal
    const closeNewKey = document.getElementById('close-new-key');
    if (closeNewKey) {
      closeNewKey.addEventListener('click', () => {
        document.getElementById('new-key-modal')?.classList.add('hidden');
      });
    }

    loadKeys();
  </script>
</AccountLayout>
