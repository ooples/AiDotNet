---
import SolutionLayout from '../../../layouts/SolutionLayout.astro';
---

<SolutionLayout
  title="Financial Services"
  seoTitle="AI for Financial Services - AiDotNet"
  seoDescription="Build trading algorithms, risk models, and financial analytics in pure C#. FinBERT, DeepAR, Chronos, GARCH, and 30+ financial AI models for .NET."
  headline="AI-powered financial intelligence. Pure .NET."
  subheadline="Build quantitative trading strategies, risk assessment systems, and financial analytics with purpose-built AI models. No Python dependency means faster execution, easier compliance, and seamless integration with existing .NET financial infrastructure."
  icon='<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
  painPoints={[
    { problem: 'Python dependency in production trading systems', solution: 'AiDotNet runs natively in .NET with zero Python overhead. No GIL bottleneck, no interop latency, no separate runtime to maintain.' },
    { problem: 'Fragmented ML libraries for financial use cases', solution: 'FinBERT sentiment, DeepAR forecasting, GARCH volatility, and portfolio optimization all in one unified library.' },
    { problem: 'Model IP protection for proprietary strategies', solution: 'AES-256-GCM encrypted model weights with three-layer obfuscation. Your alpha stays proprietary.' },
    { problem: 'Regulatory compliance for model deployment', solution: 'Self-hosted model serving with full audit trail, license management, and on-premises deployment. No data leaves your infrastructure.' },
  ]}
  capabilities={[
    {
      title: 'Market Sentiment Analysis',
      description: 'Analyze earnings calls, news articles, SEC filings, and social media for market sentiment signals.',
      models: ['FinBERT', 'FinGPT', 'SecBERT', 'BloombergGPT'],
      icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>'
    },
    {
      title: 'Time Series Forecasting',
      description: 'Predict prices, volumes, and financial metrics with state-of-the-art temporal models.',
      models: ['DeepAR', 'Chronos', 'N-BEATS', 'TFT', 'PatchTST', 'Informer'],
      icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>'
    },
    {
      title: 'Risk & Portfolio Management',
      description: 'VaR, GARCH volatility, Black-Scholes pricing, and portfolio optimization.',
      models: ['GARCH', 'VaR', 'Black-Scholes', 'Monte Carlo', 'Factor Models'],
      icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>'
    },
    {
      title: 'Anomaly & Fraud Detection',
      description: 'Detect fraudulent transactions, market manipulation, and unusual trading patterns.',
      models: ['IsolationForest', 'AutoEncoder', 'DeepSVDD', 'DAGMM', 'TranAD'],
      icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>'
    },
    {
      title: 'Document Processing',
      description: 'Extract data from financial documents, statements, and regulatory filings.',
      models: ['LayoutLMv3', 'Donut', 'PaddleOCR', 'FinBERT NER'],
      icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>'
    },
    {
      title: 'Alternative Data Analysis',
      description: 'Process satellite imagery, social media, and unstructured data for alpha signals.',
      models: ['CLIP', 'ResNet', 'BERT', 'Whisper', 'ViT'],
      icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>'
    },
  ]}
  workflow={[
    { step: 'Data ingestion', detail: 'Connect to market feeds, news APIs, and internal databases using .NET data connectors.' },
    { step: 'Feature engineering', detail: 'Build technical indicators, sentiment scores, and alternative data features with AiDotNet preprocessing.' },
    { step: 'Model training', detail: 'Train FinBERT for sentiment, DeepAR for forecasting, and anomaly detectors on historical data.' },
    { step: 'Strategy backtesting', detail: 'Backtest trading strategies using trained models against historical market data.' },
    { step: 'Model encryption', detail: 'Protect proprietary strategies with AES-256-GCM encryption and three-layer obfuscation.' },
    { step: 'Production deployment', detail: 'Deploy as REST/gRPC endpoints with license management via AiDotNet.Serving.' },
  ]}
  codeExample={`using AiDotNet;

// Sentiment analysis with AiModelBuilder
var sentimentModel = await new AiModelBuilder<float, float[], float>()
    .ConfigureModel(new FinBERT<float>())
    .ConfigureOptimizer(new AdamOptimizer<float>())
    .ConfigurePreprocessing()
    .BuildAsync(financialTexts, sentimentLabels);

var sentiment = sentimentModel.Predict(earningsCallText);

// Time series forecasting with AiModelBuilder
var forecastModel = await new AiModelBuilder<float, float[], float>()
    .ConfigureModel(new Chronos<float>("chronos-t5-large"))
    .ConfigurePreprocessing()
    .BuildAsync(historicalPrices, futureValues);

var forecast = forecastModel.Predict(recentPrices);

// Anomaly detection with AiModelBuilder
var anomalyModel = await new AiModelBuilder<float, float[], float>()
    .ConfigureModel(new IsolationForest<float>(
        contamination: 0.01f))
    .BuildAsync(normalTransactions, labels);

var anomalies = anomalyModel.Predict(newTransactions);`}
  codeTitle="Financial AI with AiModelBuilder"
/>
