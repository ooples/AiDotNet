---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const solutions = [
  {
    title: 'Financial Services',
    description: 'Trading algorithms, risk models, sentiment analysis, and time series forecasting. No Python dependency for production trading systems.',
    href: `${base}solutions/finance/`,
    models: ['FinBERT', 'Chronos', 'DeepAR', 'GARCH', 'IsolationForest'],
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
  },
  {
    title: 'Healthcare & Life Sciences',
    description: 'Medical imaging, clinical NLP, drug discovery, and federated learning for HIPAA-compliant AI across hospital networks.',
    href: `${base}solutions/healthcare/`,
    models: ['MedSAM', 'BioBERT', 'ClinicalBERT', 'FedAvg', 'SchNet'],
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>'
  },
  {
    title: 'Document AI',
    description: 'OCR, layout analysis, key-value extraction, and document understanding. Process invoices, contracts, and records at scale.',
    href: `${base}solutions/document-ai/`,
    models: ['PaddleOCR', 'LayoutLMv3', 'Donut', 'TrOCR', 'LLaVA'],
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>'
  },
];
---

<BaseLayout
  title="Industry Solutions - AiDotNet"
  description="Purpose-built AI solutions for financial services, healthcare, and document processing. Complete ML pipelines in pure C# with no Python dependency."
>
  <section class="pt-32 pb-20 relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-white dark:bg-surface-dark"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-blue/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-purple/10 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="gsap-fade-up text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-6">
          Industry solutions
        </h1>
        <p class="gsap-fade-up text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
          Purpose-built AI pipelines for regulated industries. Complete ML workflows from data ingestion to production deployment, all in pure .NET.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {solutions.map((sol) => (
          <a
            href={sol.href}
            class="gsap-fade-up group p-8 rounded-2xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50 hover:border-brand-blue/50 dark:hover:border-brand-purple/50 transition-all duration-300 hover:shadow-lg hover:shadow-brand-blue/5 dark:hover:shadow-brand-purple/5"
          >
            <div class="w-12 h-12 mb-6 flex items-center justify-center rounded-xl bg-gradient-brand text-white">
              <Fragment set:html={sol.icon} />
            </div>
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-brand-blue dark:group-hover:text-brand-purple transition-colors">
              {sol.title}
            </h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-4 leading-relaxed">{sol.description}</p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              {sol.models.map((model) => (
                <span class="inline-block px-2 py-0.5 text-xs rounded-md bg-slate-100 dark:bg-slate-900/50 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700">
                  {model}
                </span>
              ))}
            </div>
            <span class="text-sm font-medium text-brand-blue dark:text-brand-purple inline-flex items-center gap-1">
              Learn more
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
