        { name: 'Riffusion', detail: 'Real-time music generation via spectrogram diffusion.' },
        { name: 'MAGNeT', detail: 'Non-autoregressive music generation with masked modeling.' },
      ]
    },
    {
      name: 'Audio Classification & Analysis',
      description: 'Classify, tag, and analyze audio content including environmental sounds and music.',
      items: [
        { name: 'AST', detail: 'Audio Spectrogram Transformer for audio classification.' },
