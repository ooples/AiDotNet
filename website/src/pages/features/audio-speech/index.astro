        { name: 'Whisper v3', detail: 'OpenAI Whisper with 100+ language support and robust accuracy.' },
        { name: 'wav2vec 2.0', detail: 'Self-supervised speech representation learning from raw audio.' },
        { name: 'HuBERT', detail: 'Hidden-Unit BERT with offline clustering for speech representations.' },
        { name: 'WavLM', detail: 'Large-scale self-supervised speech model with denoising pretraining.' },
        { name: 'Conformer', detail: 'Convolution-augmented transformer for accurate ASR.' },
        { name: 'Canary', detail: 'NVIDIA multi-language ASR with fast-conformer architecture.' },
        { name: 'USM', detail: 'Universal Speech Model for 300+ languages.' },
        { name: 'SeamlessM4T', detail: 'Meta translation model for speech and text across 100 languages.' },
      ]
    },
    {
      name: 'Text-to-Speech (TTS)',
      description: 'Generate natural-sounding speech from text with voice control and emotion.',
      items: [
        { name: 'VITS / VITS2', detail: 'End-to-end TTS with variational inference and adversarial training.' },
        { name: 'Tacotron 2', detail: 'Sequence-to-sequence TTS with location-sensitive attention.' },
        { name: 'FastSpeech 2', detail: 'Non-autoregressive TTS with duration, pitch, and energy control.' },
        { name: 'NaturalSpeech', detail: 'Human-level TTS with variational autoencoder and flow matching.' },
        { name: 'StyleTTS 2', detail: 'Style-controllable TTS with diffusion and adversarial training.' },
        { name: 'XTTS', detail: 'Cross-lingual TTS with voice cloning from 6-second reference.' },
        { name: 'Bark', detail: 'Transformer-based TTS with music, sound effects, and multilingual support.' },
        { name: 'Tortoise TTS', detail: 'High-quality multi-voice TTS with CLVP and diffusion decoder.' },
        { name: 'Piper', detail: 'Fast, lightweight TTS optimized for edge and offline use.' },
        { name: 'MetaVoice', detail: 'Foundation model for human-like, emotional speech generation.' },
      ]
    },
    {
      name: 'Voice Conversion & Cloning',
      description: 'Transform voice characteristics while preserving content and emotion.',
      items: [
        { name: 'RVC', detail: 'Retrieval-based Voice Conversion with high quality and real-time speed.' },
        { name: 'So-VITS-SVC', detail: 'Singing voice conversion with VITS backbone.' },
        { name: 'OpenVoice', detail: 'Instant voice cloning with fine-grained style control.' },
        { name: 'VALL-E', detail: 'Neural codec language model for zero-shot voice cloning.' },
