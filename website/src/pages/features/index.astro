          </svg>
          <input
            id="feature-search"
            type="text"
            placeholder="Search models, algorithms, and features..."
            class="w-full pl-12 pr-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-blue/50 dark:focus:ring-brand-purple/50 focus:border-transparent text-sm"
          />
          <span id="search-count" class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-slate-400 hidden"></span>
        </div>
      </div>

      <!-- Quick stats -->
      <div class="gsap-fade-up flex flex-wrap justify-center gap-6 text-sm">
        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
          <span class="w-2 h-2 rounded-full bg-green-500"></span>
          <span><strong class="text-slate-900 dark:text-white">{categories.length}</strong> Categories</span>
        </div>
        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
          <span class="w-2 h-2 rounded-full bg-brand-blue"></span>
          <span><strong class="text-slate-900 dark:text-white">0</strong> Python Dependencies</span>
        </div>
        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
          <span class="w-2 h-2 rounded-full bg-brand-purple"></span>
          <span><strong class="text-slate-900 dark:text-white">BSL 1.1</strong> Licensed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Category sections -->
  <section class="pb-20 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4" id="categories-container">
        {categories.map((category, idx) => (
          <div class="feature-category gsap-fade-up" data-category-id={category.id}>
            <button
              class="category-toggle w-full flex items-center justify-between p-6 rounded-2xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50 hover:border-brand-blue/30 dark:hover:border-brand-purple/30 transition-all duration-300 group text-left"
              aria-expanded="false"
              data-target={`cat-${category.id}`}
            >
              <div class="flex items-center gap-4 min-w-0">
                <!-- Icon -->
                <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-xl bg-gradient-brand text-white">
                  <Fragment set:html={category.icon} />
                </div>

                <div class="min-w-0">
                  <div class="flex items-center gap-3 flex-wrap">
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">{category.title}</h3>
                    <span class="inline-block px-2.5 py-0.5 text-xs font-bold rounded-full bg-brand-blue/10 dark:bg-brand-purple/10 text-brand-blue dark:text-brand-purple">
                      {category.count}
                    </span>
                  </div>
                  <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">{category.tagline}</p>
                </div>
              </div>

              <!-- Expand icon -->
              <svg class="category-chevron flex-shrink-0 w-5 h-5 text-slate-400 group-hover:text-brand-blue dark:group-hover:text-brand-purple transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>

            <!-- Expandable content -->
            <div id={`cat-${category.id}`} class="category-content hidden">
              <div class="px-6 pb-6 pt-2 border-x border-b border-slate-200 dark:border-slate-700/50 rounded-b-2xl bg-white dark:bg-slate-800/50 -mt-3">
                <!-- Description -->
                <p class="text-sm text-slate-600 dark:text-slate-300 mb-6 max-w-3xl">{category.description}</p>

                <!-- Subcategories -->
                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
                  {category.subcategories.map((sub) => (
                    <div class="subcategory-card p-4 rounded-xl bg-slate-50 dark:bg-slate-900/50 border border-slate-100 dark:border-slate-700/30">
                      <h4 class="text-sm font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-gradient-brand flex-shrink-0"></span>
                        {sub.name}
                      </h4>
                      <div class="flex flex-wrap gap-1.5">
                        {sub.items.map((item) => (
                          <span class="model-tag inline-block px-2 py-0.5 text-xs rounded-md bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:border-brand-blue/50 dark:hover:border-brand-purple/50 hover:text-brand-blue dark:hover:text-brand-purple transition-colors cursor-default">
                            {item}
                          </span>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>

                <!-- Link to detail page -->
                <div class="mt-6 pt-4 border-t border-slate-100 dark:border-slate-700/30 flex items-center justify-between">
                  <a
                    href={`${base}features/${category.id}/`}
                    class="text-sm font-medium text-brand-blue dark:text-brand-purple hover:underline inline-flex items-center gap-1"
                  >
                    View full {category.title.toLowerCase()} documentation
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                  <span class="text-xs text-slate-400">{category.count} implementations</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- No results message -->
      <div id="no-results" class="hidden py-16 text-center">
        <svg class="w-16 h-16 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <p class="text-lg font-medium text-slate-500 dark:text-slate-400">No matching features found</p>
        <p class="text-sm text-slate-400 dark:text-slate-500 mt-1">Try a different search term or browse all categories below</p>
        <button id="clear-search" class="mt-4 px-4 py-2 text-sm font-medium text-brand-blue dark:text-brand-purple hover:underline">
          Clear search
        </button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-blue/5 to-brand-purple/5"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">
      <h2 class="gsap-fade-up text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-6">
        Ready to build with the most complete<br/>AI/ML library for .NET?
      </h2>
      <p class="gsap-fade-up text-slate-500 dark:text-slate-400 mb-8 max-w-2xl mx-auto">
        Install AiDotNet and start building. Training and inference are always free. BSL 1.1 licensed.
      </p>
      <div class="gsap-fade-up flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${base}docs/getting-started/installation/`}
          class="px-8 py-3 text-base font-semibold text-white rounded-xl bg-gradient-brand hover:opacity-90 transition-opacity shadow-lg shadow-brand-blue/25"
        >
          Get Started Free
        </a>
        <a
          href={`${base}pricing/`}
          class="px-8 py-3 text-base font-semibold text-slate-700 dark:text-slate-200 rounded-xl border border-slate-300 dark:border-slate-600 hover:border-brand-blue/50 dark:hover:border-brand-purple/50 transition-colors"
        >
          View Pricing
        </a>
      </div>
      <!-- Install command -->
      <div class="gsap-fade-up mt-8 inline-flex items-center gap-3 px-5 py-3 rounded-xl bg-slate-900 dark:bg-slate-800 border border-slate-700">
        <code class="text-sm text-green-400 font-mono">dotnet add package AiDotNet</code>
        <button
          class="copy-btn p-1 text-slate-400 hover:text-white transition-colors"
          data-copy="dotnet add package AiDotNet"
          aria-label="Copy install command"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Accordion toggle logic
      const toggles = document.querySelectorAll('.category-toggle');
      toggles.forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const targetId = toggle.getAttribute('data-target');
          if (!targetId) return;
          const content = document.getElementById(targetId);
          if (!content) return;

          const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
          const chevron = toggle.querySelector('.category-chevron');

          if (isExpanded) {
            content.classList.add('hidden');
            toggle.setAttribute('aria-expanded', 'false');
            toggle.classList.remove('rounded-b-none', 'border-b-0');
            if (chevron) chevron.style.transform = '';
          } else {
            content.classList.remove('hidden');
            toggle.setAttribute('aria-expanded', 'true');
            toggle.classList.add('rounded-b-none', 'border-b-0');
            if (chevron) chevron.style.transform = 'rotate(180deg)';
          }
        });
      });

      // Search logic
      const searchInput = document.getElementById('feature-search') as HTMLInputElement;
      const searchCount = document.getElementById('search-count');
      const noResults = document.getElementById('no-results');
      const categoriesContainer = document.getElementById('categories-container');
      const clearSearch = document.getElementById('clear-search');

      if (searchInput) {
        searchInput.addEventListener('input', () => {
          const query = searchInput.value.toLowerCase().trim();
          const categories = document.querySelectorAll('.feature-category');
          let visibleCount = 0;

          if (!query) {
            // Show all categories, collapse them
            categories.forEach((cat) => {
              (cat as HTMLElement).style.display = '';
              const toggle = cat.querySelector('.category-toggle');
              const targetId = toggle?.getAttribute('data-target');
              if (targetId) {
                const content = document.getElementById(targetId);
                if (content) content.classList.add('hidden');
                toggle?.setAttribute('aria-expanded', 'false');
                toggle?.classList.remove('rounded-b-none', 'border-b-0');
                const chevron = toggle?.querySelector('.category-chevron') as HTMLElement;
                if (chevron) chevron.style.transform = '';
              }
            });
            if (searchCount) searchCount.classList.add('hidden');
            if (noResults) noResults.classList.add('hidden');
            return;
          }

          categories.forEach((cat) => {
            const toggle = cat.querySelector('.category-toggle');
            const targetId = toggle?.getAttribute('data-target');
            const content = targetId ? document.getElementById(targetId) : null;
            const allText = cat.textContent?.toLowerCase() || '';
            const tags = cat.querySelectorAll('.model-tag');

            // Check if any tag matches
            let hasMatchingTag = false;
            tags.forEach((tag) => {
              const tagText = tag.textContent?.toLowerCase() || '';
              if (tagText.includes(query)) {
                hasMatchingTag = true;
                (tag as HTMLElement).classList.add('!border-brand-blue', 'dark:!border-brand-purple', '!text-brand-blue', 'dark:!text-brand-purple', '!bg-brand-blue/5', 'dark:!bg-brand-purple/5');
              } else {
                (tag as HTMLElement).classList.remove('!border-brand-blue', 'dark:!border-brand-purple', '!text-brand-blue', 'dark:!text-brand-purple', '!bg-brand-blue/5', 'dark:!bg-brand-purple/5');
              }
            });

            if (allText.includes(query)) {
              (cat as HTMLElement).style.display = '';
              visibleCount++;

              // Auto-expand matching categories
              if (content && hasMatchingTag) {
                content.classList.remove('hidden');
                toggle?.setAttribute('aria-expanded', 'true');
                toggle?.classList.add('rounded-b-none', 'border-b-0');
                const chevron = toggle?.querySelector('.category-chevron') as HTMLElement;
                if (chevron) chevron.style.transform = 'rotate(180deg)';
              }
            } else {
              (cat as HTMLElement).style.display = 'none';
            }
          });

          if (searchCount) {
            searchCount.textContent = `${visibleCount} categories`;
            searchCount.classList.remove('hidden');
          }
          if (noResults) {
            noResults.classList.toggle('hidden', visibleCount > 0);
          }
        });
      }

      if (clearSearch && searchInput) {
        clearSearch.addEventListener('click', () => {
          searchInput.value = '';
          searchInput.dispatchEvent(new Event('input'));
          searchInput.focus();
        });
      }

      // Copy button
      document.querySelectorAll('.copy-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const text = (btn as HTMLElement).dataset.copy;
          if (text) {
            navigator.clipboard.writeText(text);
            const svg = btn.querySelector('svg');
            if (svg) {
              svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>';
              setTimeout(() => {
                svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
              }, 2000);
            }
          }
        });
      });

      // Expand All / Collapse All with keyboard shortcut
      document.addEventListener('keydown', (e) => {
        if (e.key === 'e' && (e.metaKey || e.ctrlKey)) {
          e.preventDefault();
          const allToggles = document.querySelectorAll('.category-toggle');
          const anyCollapsed = Array.from(allToggles).some(
            (t) => t.getAttribute('aria-expanded') !== 'true'
          );
          allToggles.forEach((toggle) => {
            const targetId = toggle.getAttribute('data-target');
            if (!targetId) return;
            const content = document.getElementById(targetId);
            if (!content) return;
            const chevron = toggle.querySelector('.category-chevron') as HTMLElement;

            if (anyCollapsed) {
              content.classList.remove('hidden');
              toggle.setAttribute('aria-expanded', 'true');
              toggle.classList.add('rounded-b-none', 'border-b-0');
              if (chevron) chevron.style.transform = 'rotate(180deg)';
            } else {
              content.classList.add('hidden');
              toggle.setAttribute('aria-expanded', 'false');
              toggle.classList.remove('rounded-b-none', 'border-b-0');
              if (chevron) chevron.style.transform = '';
            }
          });
        }
      });
    });
  </script>
</BaseLayout>
