<BaseLayout
  title="Features - AiDotNet | Complete AI/ML Catalog"
  description="Explore 8,100+ classes across 139 modules covering neural networks, classical ML, computer vision, diffusion models, audio, reinforcement learning, and more. The complete AI/ML platform for .NET."
>
  <!-- Hero -->
  <section class="pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-white dark:bg-surface-dark"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-blue/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-purple/10 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-blue/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="gsap-fade-up inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase bg-brand-blue/10 dark:bg-brand-purple/10 text-brand-blue dark:text-brand-purple mb-6">
        8,100+ Classes &bull; 139 Modules
      </span>
      <h1 class="gsap-fade-up text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-6">
        Every AI/ML algorithm.<br/>
        <span class="text-transparent bg-gradient-to-r from-brand-blue to-brand-purple bg-clip-text">
          Pure .NET.
        </span>
      </h1>
      <p class="gsap-fade-up text-lg text-slate-500 dark:text-slate-400 max-w-3xl mx-auto mb-8">
        The most comprehensive AI and machine learning library for .NET. {categories.length} categories spanning neural networks, diffusion models, computer vision, NLP, audio, reinforcement learning, and more.
      </p>

      <!-- Search bar -->
      <div class="gsap-fade-up max-w-xl mx-auto mb-8">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
