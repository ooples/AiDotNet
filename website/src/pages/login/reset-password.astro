---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Set New Password - AiDotNet" description="Set a new password for your AiDotNet account.">
  <div class="pt-24 pb-16 min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md mx-auto px-4">
      <div class="text-center mb-8">
        <a href={base} class="inline-flex items-center gap-2 mb-6">
          <img src={`${base}logo.svg`} alt="AiDotNet" class="w-10 h-10" />
          <span class="text-2xl font-bold bg-gradient-to-r from-brand-blue to-brand-purple bg-clip-text text-transparent">
            AiDotNet
          </span>
        </a>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Set new password</h1>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
          Enter your new password below
        </p>
      </div>

      <div class="bg-white dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700 p-8 shadow-sm">
        <form id="new-password-form" class="space-y-4">
          <div>
            <label for="password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              New password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="8"
              class="w-full px-4 py-3 text-sm bg-slate-50 dark:bg-slate-700/50 border border-slate-200 dark:border-slate-600 rounded-xl focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue outline-none transition-all text-slate-900 dark:text-white placeholder-slate-400"
              placeholder="Enter new password (min. 8 characters)"
            />
          </div>

          <div>
            <label for="confirm-password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              Confirm new password
            </label>
            <input
              type="password"
              id="confirm-password"
              name="confirm-password"
              required
              minlength="8"
              class="w-full px-4 py-3 text-sm bg-slate-50 dark:bg-slate-700/50 border border-slate-200 dark:border-slate-600 rounded-xl focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue outline-none transition-all text-slate-900 dark:text-white placeholder-slate-400"
              placeholder="Confirm new password"
            />
          </div>

          <!-- Success message -->
          <div id="pw-success" class="hidden p-3 text-sm text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl">
            Password updated successfully! Redirecting to login...
          </div>

          <!-- Error message -->
          <div id="pw-error" class="hidden p-3 text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl">
          </div>

          <button
            type="submit"
            id="pw-btn"
            class="w-full px-4 py-3 text-sm font-semibold text-white rounded-xl bg-gradient-brand hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Update Password
          </button>
        </form>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const base = import.meta.env.BASE_URL || '/';

    const form = document.getElementById('new-password-form') as HTMLFormElement;
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const password = (document.getElementById('password') as HTMLInputElement).value;
        const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;
        const submitBtn = document.getElementById('pw-btn') as HTMLButtonElement;
        const errorDiv = document.getElementById('pw-error');
        const successDiv = document.getElementById('pw-success');

        if (errorDiv) errorDiv.classList.add('hidden');
        if (successDiv) successDiv.classList.add('hidden');

        if (password !== confirmPassword) {
          if (errorDiv) {
            errorDiv.textContent = 'Passwords do not match.';
            errorDiv.classList.remove('hidden');
          }
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Updating...';

        const { error } = await supabase.auth.updateUser({ password });

        if (error) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Update Password';
          if (errorDiv) {
            errorDiv.textContent = error.message;
            errorDiv.classList.remove('hidden');
          }
        } else {
          if (successDiv) successDiv.classList.remove('hidden');
          submitBtn.disabled = true;
          submitBtn.textContent = 'Password Updated';
          // Redirect to login after 2 seconds
          setTimeout(() => {
            window.location.href = `${base}login/`;
          }, 2000);
        }
      });
    }
  </script>
</BaseLayout>
