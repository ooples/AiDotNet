---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Reset Password - AiDotNet" description="Reset your AiDotNet account password.">
  <div class="pt-24 pb-16 min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md mx-auto px-4">
      <div class="text-center mb-8">
        <a href={base} class="inline-flex items-center gap-2 mb-6">
          <img src={`${base}logo.svg`} alt="AiDotNet" class="w-10 h-10" />
          <span class="text-2xl font-bold bg-gradient-to-r from-brand-blue to-brand-purple bg-clip-text text-transparent">
            AiDotNet
          </span>
        </a>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Reset your password</h1>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
          Enter your email and we'll send you a link to reset your password
        </p>
      </div>

      <div class="bg-white dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700 p-8 shadow-sm">
        <form id="reset-form" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
              Email address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 text-sm bg-slate-50 dark:bg-slate-700/50 border border-slate-200 dark:border-slate-600 rounded-xl focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue outline-none transition-all text-slate-900 dark:text-white placeholder-slate-400"
              placeholder="you@example.com"
            />
          </div>

          <!-- Success message -->
          <div id="reset-success" class="hidden p-3 text-sm text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl">
            Check your email for a password reset link.
          </div>

          <!-- Error message -->
          <div id="reset-error" class="hidden p-3 text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl">
          </div>

          <button
            type="submit"
            id="reset-btn"
            class="w-full px-4 py-3 text-sm font-semibold text-white rounded-xl bg-gradient-brand hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Send Reset Link
          </button>
        </form>
      </div>

      <p class="mt-6 text-center text-sm text-slate-500 dark:text-slate-400">
        Remember your password?
        <a href={`${base}login/`} class="font-medium text-brand-blue hover:underline">
          Back to sign in
        </a>
      </p>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const base = import.meta.env.BASE_URL || '/';

    const form = document.getElementById('reset-form') as HTMLFormElement;
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = (document.getElementById('email') as HTMLInputElement).value;
        const submitBtn = document.getElementById('reset-btn') as HTMLButtonElement;
        const errorDiv = document.getElementById('reset-error');
        const successDiv = document.getElementById('reset-success');

        if (errorDiv) errorDiv.classList.add('hidden');
        if (successDiv) successDiv.classList.add('hidden');

        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';

        const { error } = await supabase.auth.resetPasswordForEmail(email, {
          redirectTo: `${window.location.origin}${base}login/reset-password/`,
        });

        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Reset Link';

        if (error) {
          if (errorDiv) {
            errorDiv.textContent = error.message;
            errorDiv.classList.remove('hidden');
          }
        } else {
          if (successDiv) successDiv.classList.remove('hidden');
          // Disable button after success to prevent spam
          submitBtn.disabled = true;
          submitBtn.textContent = 'Email Sent';
        }
      });
    }
  </script>
</BaseLayout>
