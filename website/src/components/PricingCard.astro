---
interface Props {
  tier: string;
  price: string;
  interval?: string;
  description: string;
  features: string[];
  cta: string;
  ctaHref?: string;
  highlighted?: boolean;
  stripeTier?: string;
}

const { tier, price, interval, description, features, cta, ctaHref, highlighted = false, stripeTier } = Astro.props;
---

<div class:list={[
  'gsap-fade-up relative flex flex-col rounded-2xl border p-8 transition-all duration-300',
  highlighted
    ? 'border-brand-purple/50 bg-gradient-to-b from-brand-purple/5 to-transparent dark:from-brand-purple/10 shadow-xl shadow-brand-purple/10 scale-[1.02]'
    : 'border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50 hover:border-brand-blue/30'
]}>
  {highlighted && (
    <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 text-xs font-semibold text-white rounded-full bg-gradient-brand">
      Most Popular
    </div>
  )}

  <div class="mb-6">
    <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">{tier}</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400">{description}</p>
  </div>

  <div class="mb-6">
    <span class="text-4xl font-bold text-slate-900 dark:text-white">{price}</span>
    {interval && <span class="text-sm text-slate-500 dark:text-slate-400">/{interval}</span>}
  </div>

  <ul class="flex-1 space-y-3 mb-8">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-300">
        <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        {feature}
      </li>
    ))}
  </ul>

  {stripeTier ? (
    <button
      class:list={[
        'checkout-btn w-full py-3 px-6 rounded-lg text-sm font-semibold transition-all duration-200',
        highlighted
          ? 'text-white bg-gradient-brand hover:opacity-90 hover:shadow-lg hover:shadow-brand-purple/25'
          : 'text-brand-blue dark:text-brand-purple border border-brand-blue/30 dark:border-brand-purple/30 hover:bg-brand-blue/5 dark:hover:bg-brand-purple/5'
      ]}
      data-tier={stripeTier}
    >
      {cta}
    </button>
  ) : (
    <a
      href={ctaHref}
      class:list={[
        'block w-full text-center py-3 px-6 rounded-lg text-sm font-semibold transition-all duration-200',
        highlighted
          ? 'text-white bg-gradient-brand hover:opacity-90 hover:shadow-lg hover:shadow-brand-purple/25'
          : 'text-brand-blue dark:text-brand-purple border border-brand-blue/30 dark:border-brand-purple/30 hover:bg-brand-blue/5 dark:hover:bg-brand-purple/5'
      ]}
    >
      {cta}
    </a>
  )}
</div>
