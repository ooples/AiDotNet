---
interface ComparisonRow {
  feature: string;
  aidotnet: string;
  mlnet: string;
  torchsharp: string;
  pytorch: string;
  /** "positive" highlights AiDotNet cell in green, "metric" uses brand gradient, "neutral" uses default text */
  aidotnetStyle?: "positive" | "metric" | "neutral";
}

const rows: ComparisonRow[] = [
  { feature: "Language", aidotnet: "Pure C#", mlnet: "C# + ONNX", torchsharp: "C# wrapper", pytorch: "Python", aidotnetStyle: "positive" },
  { feature: "Neural Network Layers", aidotnet: "160+", mlnet: "~10", torchsharp: "50+", pytorch: "100+", aidotnetStyle: "metric" },
  { feature: "Classical ML Algorithms", aidotnet: "155+", mlnet: "~30", torchsharp: "None", pytorch: "None", aidotnetStyle: "metric" },
  { feature: "Computer Vision Models", aidotnet: "115+", mlnet: "Limited", torchsharp: "Via LibTorch", pytorch: "Via torchvision", aidotnetStyle: "metric" },
  { feature: "Vision-Language Models", aidotnet: "165+", mlnet: "None", torchsharp: "None", pytorch: "Via HF", aidotnetStyle: "metric" },
  { feature: "Diffusion Models", aidotnet: "75+", mlnet: "None", torchsharp: "None", pytorch: "Via diffusers", aidotnetStyle: "metric" },
  { feature: "Audio / Speech / TTS", aidotnet: "250+", mlnet: "None", torchsharp: "Limited", pytorch: "Via torchaudio", aidotnetStyle: "metric" },
  { feature: "Reinforcement Learning", aidotnet: "50+", mlnet: "None", torchsharp: "Manual", pytorch: "Via SB3", aidotnetStyle: "metric" },
  { feature: "GPU Support", aidotnet: "Any GPU (6 backends)", mlnet: "ONNX only", torchsharp: "CUDA only", pytorch: "CUDA only", aidotnetStyle: "positive" },
  { feature: "Federated Learning", aidotnet: "180+", mlnet: "None", torchsharp: "None", pytorch: "Via Flower", aidotnetStyle: "metric" },
  { feature: "Model Serving", aidotnet: "Built-in", mlnet: "Manual", torchsharp: "None", pytorch: "TorchServe", aidotnetStyle: "positive" },
  { feature: "Runtime Dependency", aidotnet: "None", mlnet: "None", torchsharp: "~700MB LibTorch", pytorch: "Python runtime", aidotnetStyle: "positive" },
];

function aidotnetCellClass(style?: string): string {
  switch (style) {
    case "positive": return "py-3 px-4 font-semibold text-green-500";
    case "metric": return "py-3 px-4 font-semibold text-brand-blue dark:text-brand-purple";
    default: return "py-3 px-4 text-slate-500 dark:text-slate-400";
  }
}

function competitorCellClass(value: string): string {
  const lower = value.toLowerCase();
  if (lower === "none" || lower === "limited" || lower === "manual") {
    return "py-3 px-4 text-slate-400 dark:text-slate-500";
  }
  if (lower.includes("700mb") || lower.includes("python runtime")) {
    return "py-3 px-4 text-red-400 dark:text-red-500";
  }
  return "py-3 px-4 text-slate-500 dark:text-slate-400";
}
---

<div class="gsap-fade-up overflow-x-auto">
  <table class="w-full text-sm text-left">
    <caption class="sr-only">Feature comparison between AiDotNet, ML.NET, TorchSharp, and PyTorch</caption>
    <thead>
      <tr class="border-b border-slate-200 dark:border-slate-700">
        <th scope="col" class="py-4 pr-4 text-slate-500 dark:text-slate-400 font-medium">Feature</th>
        <th scope="col" class="py-4 px-4 font-semibold text-transparent bg-gradient-to-r from-brand-blue to-brand-purple bg-clip-text">AiDotNet</th>
        <th scope="col" class="py-4 px-4 text-slate-500 dark:text-slate-400 font-medium">ML.NET</th>
        <th scope="col" class="py-4 px-4 text-slate-500 dark:text-slate-400 font-medium">TorchSharp</th>
        <th scope="col" class="py-4 px-4 text-slate-500 dark:text-slate-400 font-medium">PyTorch</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
      {rows.map((row) => (
        <tr>
          <th scope="row" class="py-3 pr-4 text-slate-600 dark:text-slate-300 font-normal">{row.feature}</th>
          <td class={aidotnetCellClass(row.aidotnetStyle)}>{row.aidotnet}</td>
          <td class={competitorCellClass(row.mlnet)}>{row.mlnet}</td>
          <td class={competitorCellClass(row.torchsharp)}>{row.torchsharp}</td>
          <td class={competitorCellClass(row.pytorch)}>{row.pytorch}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
