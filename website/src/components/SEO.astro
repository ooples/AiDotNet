---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
}

const { title, description, image = '/og-image.png', canonical } = Astro.props;
const siteUrl = import.meta.env.SITE || 'https://aidotnet.dev';
const base = import.meta.env.BASE_URL || '/';
// Strip the base path prefix from pathname to get the clean path for canonical URLs
const cleanPath = Astro.url.pathname.startsWith(base) && base !== '/'
  ? Astro.url.pathname.slice(base.length - 1)
  : Astro.url.pathname;
const canonicalUrl = canonical || new URL(cleanPath, siteUrl).toString();
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, siteUrl).toString()} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, siteUrl).toString()} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "AiDotNet",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Windows, Linux, macOS",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": description,
  "url": canonicalUrl
})} />
